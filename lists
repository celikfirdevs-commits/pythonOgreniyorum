#Add a new email to a set of newsletter subscribers. Then, remove
#an email from the set without causing an error even if the email wasn't there.

aboneler= {"fc@gmail.com", "dr@yahoo.com","re@yahoo.com"}

aboneler.add("as@gmail.com")

print(aboneler)

#remove(): Eğer silmek istediğiniz e-posta listede yoksa hata verir ve program durur.
#discard(): Eğer e-posta listede yoksa hiçbir şey yapmaz, 
#hata vermez ve program sessizce devam eder.

aboneler.remove("dr@yahoo.com")
print(aboneler)

aboneler.discard("fd@gmail.com")

